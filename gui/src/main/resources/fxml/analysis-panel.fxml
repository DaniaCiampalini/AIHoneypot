<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.aihoneypot.gui.controller.AnalysisController"
      spacing="20" style="-fx-padding: 20;">

    <!-- Title -->
    <Label text="🔍 Direct Analysis" styleClass="chart-title">
        <font>
            <Font name="System Bold" size="18.0"/>
        </font>
    </Label>

    <Label text="Analyze websites, accounts, and content for bot/AI detection" styleClass="small-label">
        <font>
            <Font size="12.0"/>
        </font>
    </Label>

    <Separator/>

    <!-- Analysis Type Selection -->
    <VBox spacing="8">
        <Label text="Analysis Type:" styleClass="card-title">
            <font>
                <Font name="System Bold" size="13.0"/>
            </font>
        </Label>
        <ComboBox fx:id="analysisTypeCombo" prefWidth="300" styleClass="combo-box"/>
    </VBox>

    <!-- Input Field -->
    <VBox spacing="8">
        <Label text="Input:" styleClass="card-title">
            <font>
                <Font name="System Bold" size="13.0"/>
            </font>
        </Label>
        <TextField fx:id="inputField"
                   promptText="Enter URL, username, email, IP, or User-Agent"
                   prefHeight="40"
                   styleClass="text-field">
            <font>
                <Font size="13.0"/>
            </font>
        </TextField>
    </VBox>

    <!-- Details/Context Area -->
    <VBox spacing="8">
        <Label text="Additional Details (Optional):" styleClass="card-title">
            <font>
                <Font name="System Bold" size="13.0"/>
            </font>
        </Label>
        <TextArea fx:id="detailsArea"
                  promptText="Add any additional context, headers, or notes..."
                  prefRowCount="4"
                  wrapText="true"
                  styleClass="text-area">
            <font>
                <Font size="12.0" name="Monospaced"/>
            </font>
        </TextArea>
    </VBox>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="analyzeButton"
                text="🔍 Analyze"
                onAction="#handleAnalyze"
                prefWidth="120"
                styleClass="button-primary">
            <font>
                <Font size="13.0" name="System Bold"/>
            </font>
        </Button>

        <Button text="Clear"
                onAction="#handleClear"
                prefWidth="100"
                styleClass="button"/>

        <Region HBox.hgrow="ALWAYS"/>

        <ProgressIndicator fx:id="loadingIndicator"
                          visible="false"
                          prefHeight="30"
                          prefWidth="30"/>
    </HBox>

    <Separator/>

    <!-- Result Pane -->
    <VBox fx:id="resultPane" spacing="15" visible="false" styleClass="result-pane">

        <Label text="📊 Analysis Result" styleClass="chart-title">
            <font>
                <Font name="System Bold" size="16.0"/>
            </font>
        </Label>

        <ScrollPane fitToWidth="true" prefHeight="400"
                   style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="10">
                <Label fx:id="resultLabel"
                       wrapText="true"
                       style="-fx-text-fill: #3E4C5E; -fx-line-spacing: 3px;">
                    <font>
                        <Font size="13.0" name="System"/>
                    </font>
                </Label>
            </VBox>
        </ScrollPane>
    </VBox>

    <!-- Info Footer -->
    <Label text="💡 Tip: This tool performs heuristic analysis. For accurate results, provide as much context as possible."
           styleClass="small-label"
           wrapText="true">
        <font>
            <Font size="11.0" name="System Italic"/>
        </font>
    </Label>

</VBox>

